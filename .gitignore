# API keys — never commit this
.env

# Conda environment
.conda/
*.egg-info/

# Python cache
__pycache__/
*.pyc
*.pyo

# Database files
data/db/*.db

# Raw API data — we exclude this because it can be
# regenerated by running the scripts
data/raw/

# Jupyter checkpoints
.ipynb_checkpoints/

# VSCode settings
.vscode/